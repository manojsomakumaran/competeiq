# CompeteIQ environment configuration
# Copy to .env and fill in values. Never commit .env to git.

# --- Required: LLM + Observability ---
OPENAI_API_KEY=sk-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- Optional: paths ---
# Directory containing catalog JSON files (local default: ./datasets)
COMPETEIQ_DATA_DIR=./datasets

# Directory for persistent ChromaDB (local default: ./.chroma)
COMPETEIQ_CHROMA_DIR=./.chroma

# Chroma persistence mode: persistent | memory
COMPETEIQ_CHROMA_MODE=persistent

# --- Optional: runtime ---
COMPETEIQ_SESSION_PREFIX=competeiq
COMPETEIQ_LOG_LEVEL=INFO
COMPETEIQ_OUR_COMPANY=Company X

# --- Optional: Gradio ---
GRADIO_SHARE=false
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
